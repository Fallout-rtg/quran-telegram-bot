{
  "version": 2,
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "assets/**", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/bot-webhook", "destination": "/api/index.py" },
    { "source": "/((?!bot-webhook).*)" , "destination": "/index.html" }
  ]
}
